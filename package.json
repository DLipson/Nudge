{
  "name": "nudge",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:watch\" \"wait-on http://localhost:3000 file:dist-electron/main.js && electron dist-electron/main.js\"",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:watch": "tsc -w -p electron/tsconfig.json",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^4.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nudge.app",
    "productName": "Nudge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
